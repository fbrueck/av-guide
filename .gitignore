.venv/
__pycache__/
*.pyc
# Per-guide pipeline artifacts (guides/<id>/data/<pipeline>/…) are gitignored;
# scoped to the guides tree so it never clobbers source dirs named `data`
# (e.g. route-map/src/data, the webapp's data-adapter boundary).
guides/*/data/
*.pdf
.claude/worktrees

# route-map deployed snapshot (ADR-0003): a separate, deliberately-updated
# committed copy of the four consumed artifacts, baked into the GitHub Pages
# build under Vite's public/ dir. Ignore the whole snapshot tree, then
# un-ignore EXACTLY the four published files — a noisy local pipeline rerun
# copied here can never accidentally publish extra data. The live
# guides/*/data/ tree above stays ignored; publishing is an explicit act.
route-map/public/guide-data/**
!route-map/public/guide-data/**/
!route-map/public/guide-data/parse-routes/03_structured/routes.json
!route-map/public/guide-data/fetch-pois/04_final/pois.geojson
!route-map/public/guide-data/fetch-pois/04_final/place_pois.jsonl
!route-map/public/guide-data/fetch-pois/04_final/entry_pois.jsonl